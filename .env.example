SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
RECEIVER_EMAIL=receiver@example.com

TARGET_URL=https://example.com/product
MONITOR_INTERVAL_SECONDS=30
PORT=3000

VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

TOSS_API_BASE_URL=https://apps-in-toss-api.toss.im

# Smart Message campaign code from Apps in Toss console.
TOSS_TEMPLATE_SET_CODE=your-template-set-code

# Notification agreement code from Apps in Toss console.
# This is the value used by requestNotificationAgreement({ options: { templateCode } }).
TOSS_NOTIFICATION_TEMPLATE_CODE=your-notification-template-code

# Use either inline PEM values with escaped newlines/base64, or file paths.
TOSS_MTLS_CERT=
TOSS_MTLS_KEY=
TOSS_MTLS_CA=
TOSS_MTLS_CERT_PATH=
TOSS_MTLS_KEY_PATH=
TOSS_MTLS_CA_PATH=
TOSS_MTLS_PASSPHRASE=

APPS_IN_TOSS_SERVER_URL=https://alert-watch.onrender.com
APPS_IN_TOSS_PUBLIC_URL=https://alert-watch.onrender.com
APPS_IN_TOSS_DEPLOYMENT_ID=
APPS_IN_TOSS_NOTIFICATION_TEMPLATE_CODE=
